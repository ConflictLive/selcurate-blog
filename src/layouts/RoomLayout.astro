---
import BaseLayout from './BaseLayout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import EmailCapture from '../components/EmailCapture.tsx';

interface Category {
  id: string;
  name: string;
  slug: string;
  articleCount: number;
}

interface Props {
  roomId: string;
  roomName: string;
  roomSlug: string;
  description: string;
  categories: Category[];
}

const { roomId, roomName, roomSlug, description, categories } = Astro.props;
---

<BaseLayout title={roomName} description={description}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-20">
    <!-- Room header -->
    <ScrollReveal>
      <header class="text-center mb-16">
        <nav class="text-sm text-foreground-muted mb-4" aria-label="Breadcrumb">
          <a href="/" class="hover:text-foreground transition-colors">Home</a>
          <span class="mx-1.5 text-border">/</span>
          <span class="text-foreground">{roomName}</span>
        </nav>
        <h1 class="text-hero font-bold font-heading text-foreground mb-4">
          {roomName}
        </h1>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          {description}
        </p>
      </header>
    </ScrollReveal>

    <!-- Category grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {categories.map((cat, i) => (
        <ScrollReveal delay={i * 80}>
          <a
            href={`/${roomSlug}/${cat.slug}/`}
            class="group block rounded-xl border border-border bg-card p-6 hover:border-primary/30 hover:shadow-card-hover transition-all duration-300"
          >
            <h2 class="text-lg font-semibold text-foreground group-hover:text-primary transition-colors mb-2">
              {cat.name}
            </h2>
            <p class="text-sm text-foreground-muted">
              {cat.articleCount > 0
                ? `${cat.articleCount} article${cat.articleCount !== 1 ? 's' : ''}`
                : 'Coming soon'}
            </p>
            <span class="inline-flex items-center gap-1 mt-3 text-sm text-primary opacity-0 group-hover:opacity-100 transition-opacity">
              Explore &rarr;
            </span>
          </a>
        </ScrollReveal>
      ))}
    </div>

    <!-- Latest articles in this room (slot for dynamic content) -->
    <slot />

    <!-- Email capture -->
    <ScrollReveal delay={200}>
      <div class="mt-16 max-w-xl mx-auto">
        <EmailCapture client:visible />
      </div>
    </ScrollReveal>
  </div>
</BaseLayout>
