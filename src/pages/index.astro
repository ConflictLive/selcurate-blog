---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import EmailCapture from '../components/EmailCapture.tsx';
import Hero3D from '../components/Hero3D.tsx';
import ProductCard from '../components/ProductCard.astro';
import dealsData from '../data/deals.json';
import roomsData from '../data/rooms.json';
import recentData from '../data/recent-articles.json';

const activeRooms = roomsData.rooms.filter((r) => r.active);
const deals = dealsData.deals;
const recentArticles = recentData.articles;
---

<BaseLayout title="Selcurate" description="Carefully selected home products. Real data, real user insights.">
  <!-- Hero section with 3D background -->
  <section class="relative min-h-[70vh] flex items-center overflow-hidden">
    <!-- 3D background — loads async, mobile falls back to gradient -->
    <div class="hidden lg:block">
      <Hero3D client:idle />
    </div>

    <!-- Mobile fallback gradient -->
    <div class="absolute inset-0 lg:hidden bg-gradient-to-br from-primary/10 via-transparent to-accent/10" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20">
      <ScrollReveal>
        <div class="max-w-2xl">
          <h1 class="text-hero font-extrabold font-heading text-foreground leading-[1.1] mb-6">
            Home products,<br />
            <span class="text-primary glow-text">data-driven.</span>
          </h1>
          <p class="text-lg text-foreground-muted mb-8 max-w-lg">
            We aggregate specs, reviews, and community feedback so you don't have to.
            Real data, no fluff.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="/office/"
              class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-medium text-white hover:bg-primary-hover transition-colors"
            >
              Explore Office &rarr;
            </a>
            <a
              href="/deals/"
              class="inline-flex items-center gap-2 rounded-lg border border-border px-6 py-3 text-sm font-medium text-foreground hover:bg-card transition-colors"
            >
              View Deals
            </a>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Stats bar — values update as bot publishes content -->
  <!-- Hidden until real data exists; bot will update src/data/stats.json -->


  <!-- Rooms -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-section">
    <ScrollReveal>
      <div class="text-center mb-10">
        <h2 class="text-h2 font-bold font-heading text-foreground mb-3">Browse by Room</h2>
        <p class="text-foreground-muted">Find the right products for every space in your home.</p>
      </div>
    </ScrollReveal>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {activeRooms.map((room, i) => (
        <ScrollReveal delay={i * 80}>
          <a
            href={`/${room.slug}/`}
            class="group block rounded-xl border border-border bg-card p-6 hover:border-primary/30 hover:shadow-card-hover transition-all duration-300"
          >
            <h3 class="text-lg font-semibold text-foreground group-hover:text-primary transition-colors mb-2">
              {room.name}
            </h3>
            <p class="text-sm text-foreground-muted mb-3">
              {room.categories.length} categories
            </p>
            <div class="flex flex-wrap gap-2">
              {room.categories.slice(0, 3).map((cat) => (
                <span class="text-xs rounded-md bg-background-alt border border-border px-2 py-1 text-foreground-muted">
                  {cat.name}
                </span>
              ))}
            </div>
          </a>
        </ScrollReveal>
      ))}
    </div>
  </section>

  <!-- Hot Deals -->
  {deals.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-section">
      <ScrollReveal>
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-h2 font-bold font-heading text-foreground">Hot Deals</h2>
          <a href="/deals/" class="text-sm text-primary hover:text-primary-hover transition-colors">
            View all &rarr;
          </a>
        </div>
      </ScrollReveal>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {deals.slice(0, 8).map((deal: any) => (
          <ProductCard
            name={deal.name}
            price={deal.price}
            originalPrice={deal.originalPrice}
            rating={deal.rating}
            reviewCount={deal.reviewCount}
            image={deal.image}
            bestFor={deal.bestFor}
            href={deal.href || '#'}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Latest Articles -->
  {recentArticles.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-section">
      <ScrollReveal>
        <h2 class="text-h2 font-bold font-heading text-foreground mb-8">Latest Articles</h2>
      </ScrollReveal>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentArticles.slice(0, 6).map((article: any, i: number) => (
          <ScrollReveal delay={i * 60}>
            <a
              href={`/${article.room_id}/${article.category}/${article.id}/`}
              class="group block rounded-xl border border-border bg-card p-5 hover:border-primary/30 hover:shadow-card-hover transition-all duration-300"
            >
              <span class="text-xs font-medium text-primary bg-primary/10 rounded-md px-2 py-0.5">
                {article.room_id}
              </span>
              <h3 class="mt-3 text-base font-semibold text-foreground group-hover:text-primary transition-colors line-clamp-2">
                {article.title}
              </h3>
              <p class="mt-2 text-sm text-foreground-muted line-clamp-2">
                {article.description}
              </p>
            </a>
          </ScrollReveal>
        ))}
      </div>
    </section>
  )}

  <!-- Empty state when no content yet -->
  {recentArticles.length === 0 && deals.length === 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-section text-center">
      <ScrollReveal>
        <div class="max-w-md mx-auto">
          <div class="text-6xl mb-4 opacity-30">&#128218;</div>
          <h2 class="text-h2 font-bold font-heading text-foreground mb-3">Content coming soon</h2>
          <p class="text-foreground-muted mb-6">
            We're researching and writing our first batch of data-driven guides.
            Subscribe to get notified when we publish.
          </p>
        </div>
      </ScrollReveal>
    </section>
  )}

  <!-- Email capture -->
  <section class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8 py-section">
    <ScrollReveal>
      <EmailCapture client:visible />
    </ScrollReveal>
  </section>

</BaseLayout>
